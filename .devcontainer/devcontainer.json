{
    "name": "k8s-proxy",
    "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/mpriscella/features/kind:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "kubectl": "latest",
            "helm": "none",
            "minikube": "none"
        },
        "ghcr.io/devcontainers/features/go:1": {
            "version": "latest",
            "installTools": "true"
        }
    },
    "privileged": true,
    "remoteUser": "vscode",
    "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go"
            ],
            "settings": {
                "go.alternateTools": {
                    "go": "/usr/local/bin/go-cap-wrapper",
                    "dlv": "/usr/local/bin/dlv-cap-wrapper"
                }
            }
        }
    }
}
